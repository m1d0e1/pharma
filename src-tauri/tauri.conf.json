{
  "productName": "Pharmacy Local Enforcer",
  "version": "0.1.0",
  "identifier": "com.pharma.system",
  "build": {
    "beforeDevCommand": "cross-env NEXT_PUBLIC_TAURI=1 next dev",
    "beforeBuildCommand": "npm run seed:db && npm run build:tauri",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Pharmacy Local Enforcer",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "pharma_local.db"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Pharma Management Team"
  },
  "plugins": {
    "sql": {
      "sqlite": [
        "sqlite:pharma_local.db"
      ]
    },
    "updater": {
      "endpoints": [
        "https://YOUR_UPDATE_SERVER_URL_HERE/update.json"
      ],
      "pubkey": "YOUR_UPDATER_PUBLIC_KEY_HERE"
    }
  }
}