{
    "productName": "Pharmacy Local Enforcer",
    "version": "0.2.14",
    "identifier": "com.pharma.system",
    "build": {
        "beforeDevCommand": "cross-env NEXT_PUBLIC_TAURI=1 next dev",
        "beforeBuildCommand": "npm run seed:db \u0026\u0026 npm run build:tauri",
        "devUrl": "http://localhost:3000",
        "frontendDist": "../out"
    },
    "app": {
        "windows": [
            {
                "title": "Pharmacy Local Enforcer",
                "width": 1280,
                "height": 800,
                "resizable": true,
                "maximized": true,
                "fullscreen": false,
                "label": "main"
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        },
        "withGlobalTauri": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": [
            "pharma_local.db"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "publisher": "Pharma Management Team",
        "createUpdaterArtifacts": true
    },
    "plugins": {
        "sql": {
            "sqlite": [
                "sqlite:pharma_local.db"
            ]
        },
        "updater": {
            "endpoints": [
                "https://github.com/m1d0e1/pharma/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0NjEwRDJDMDA5NjI4RTkKUldUcEtKWUFMQTFoNUdtcmpTVlJVUExhMnJzbWUvYUVxUldEWURMUmVacGxuZEVFckpNQmgxSzUK"
        }
    }
}


